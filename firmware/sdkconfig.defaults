CONFIG_BOOTLOADER_LOG_LEVEL_NONE=y
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_PARTITION_TABLE_CUSTOM=y
# OTA removed — single factory partition, no ota_0/ota_1
# CONFIG_ESP_HTTPS_OTA_ALLOW_HTTP is not set
CONFIG_PM_ENABLE=y
CONFIG_PM_DFS_INIT_AUTO=y
CONFIG_ESP_CONSOLE_NONE=y
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y
# CONFIG_ESP_WIFI_NVS_ENABLED is not set
# CONFIG_ESP_WIFI_SOFTAP_SUPPORT is not set
CONFIG_LOG_DEFAULT_LEVEL_NONE=y
# CONFIG_LWIP_IPV6 is not set
CONFIG_LWIP_TCP_MSS=1460
CONFIG_MBEDTLS_TLS_CLIENT_ONLY=y
# HTTPS via esp_http_client with full Mozilla CA bundle (required for finnhub.io / TLS)
CONFIG_MW_HTTP_USE_ESP=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL=y
